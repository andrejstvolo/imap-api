# IMAP API — Environment Variables for Plesk Deployment
# Copy this file to .env and fill in your values

# API Key for securing the REST API
# All AI agents (Manus, Claude, Kimi) must send this key as:
#   Authorization: Bearer <your-key>
# Generate a strong random key, e.g.: openssl rand -hex 32
API_KEY=your-strong-secret-api-key-here

# Redis connection (default works if Redis is on localhost)
# dbs__redis=redis://127.0.0.1:6379/8

# API server port (Plesk will proxy to this)
# api__port=3000

# Set to production for Plesk
NODE_ENV=production
