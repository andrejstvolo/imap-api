# Email Automation Hub - Environment Configuration

# ============================================
# Core Application Settings
# ============================================
NODE_ENV=production
PORT=3000
API_PORT=3000
AGENT_BRIDGE_PORT=3001
APPROVAL_QUEUE_PORT=3002

# ============================================
# Security Settings
# ============================================
# Generate a strong API key: openssl rand -base64 32
API_KEY=your-super-secure-api-key-here
JWT_SECRET=your-jwt-secret-for-agent-authentication
ENCRYPTION_KEY=your-32-char-encryption-key-for-sensitive-data

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Redis Configuration
# ============================================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# Database (for approval queue persistence)
# ============================================
DATABASE_URL=postgresql://user:pass@localhost:5432/email_automation

# ============================================
# AI Agent Integration
# ============================================
# OpenAI for email processing
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4

# Claude API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Custom AI Agent Endpoints
OPENCLAW_AGENT_URL=http://localhost:8000
MANUS_AGENT_URL=http://localhost:8001
CLAUDE_CODE_AGENT_URL=http://localhost:8002

# ============================================
# Email Processing Settings
# ============================================
# Maximum emails to process per batch
BATCH_SIZE=50
# Email fetch interval (milliseconds)
FETCH_INTERVAL=30000
# Draft auto-save interval
DRAFT_AUTOSAVE_INTERVAL=30000

# ============================================
# Autopilot Mode Settings
# ============================================
# Enable autopilot globally
AUTOPILOT_ENABLED=false
# Confidence threshold for auto-sending (0-1)
AUTOPILOT_CONFIDENCE_THRESHOLD=0.85
# Maximum emails per hour in autopilot mode
AUTOPILOT_RATE_LIMIT=20
# Escalation email for manual review
AUTOPILOT_ESCALATION_EMAIL=admin@yourcompany.com

# ============================================
# Multi-Account Manager (11 Businesses)
# ============================================
# Account configuration file path
ACCOUNTS_CONFIG_PATH=./config/accounts.json
# Maximum concurrent IMAP connections
MAX_IMAP_CONNECTIONS=20
# Connection timeout (milliseconds)
IMAP_CONNECTION_TIMEOUT=30000

# ============================================
# Webhook Settings
# ============================================
WEBHOOK_URL=https://your-service.com/webhooks/email
WEBHOOK_SECRET=your-webhook-signing-secret

# ============================================
# SnappyMail Integration
# ============================================
SNAPPYMAIL_URL=http://localhost:8888
SNAPPYMAIL_API_KEY=your-snappymail-api-key

# ============================================
# Logging
# ============================================
LOG_LEVEL=info
LOG_FILE=./logs/email-automation.log

# ============================================
# Notification Settings
# ============================================
# Slack webhook for notifications
SLACK_WEBHOOK_URL=
# Email for system alerts
ALERT_EMAIL=admin@yourcompany.com
