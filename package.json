{
  "name": "email-automation-hub",
  "version": "2.0.0",
  "description": "Unified Email Automation System for Multi-Business Management",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:api": "node server.js",
    "start:agent-bridge": "node services/agent-bridge/server.js",
    "start:approval-queue": "node services/approval-queue/server.js",
    "start:all": "concurrently \"npm run start:api\" \"npm run start:agent-bridge\" \"npm run start:approval-queue\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "licenses": "npm-license-crawler --production --csv ./licenses.csv",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "keywords": [
    "IMAP",
    "email",
    "automation",
    "multi-account",
    "AI-agent",
    "approval-workflow"
  ],
  "author": "Email Automation Hub",
  "license": "AGPL-3.0-or-later",
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@hapi/hapi": "^21.3.2",
    "@hapi/inert": "^7.1.0",
    "@hapi/joi": "^17.1.1",
    "@hapi/vision": "^7.0.3",
    "bcryptjs": "^2.4.3",
    "bull": "^4.11.3",
    "bull-board": "^2.1.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "email-reply-parser": "^1.2.2",
    "exponential-backoff": "^3.1.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.0",
    "hapi-pino": "^12.1.0",
    "hapi-swagger": "^17.1.0",
    "he": "^1.2.0",
    "helmet": "^7.0.0",
    "html-to-text": "^9.0.5",
    "imapflow": "^1.0.147",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "libmime": "^5.2.1",
    "linkifyjs": "^4.1.1",
    "msgpack5": "^6.0.2",
    "node-fetch": "^3.3.2",
    "nodemailer": "^6.9.5",
    "openai": "^4.11.1",
    "pino": "^8.15.1",
    "pino-pretty": "^10.2.0",
    "prom-client": "^14.2.0",
    "qs": "^6.11.2",
    "sanitize-html": "^2.11.0",
    "uuid": "^9.0.0",
    "wild-config": "^1.5.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.1",
    "eslint": "^8.49.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-security": "^1.7.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "npm-license-crawler": "^0.2.1",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
